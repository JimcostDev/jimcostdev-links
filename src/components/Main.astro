---
import SocialButton from "./SocialButton.astro";
import YoutubeIcon from "../components/icons/YouTube.astro";
import GitHubIcon from "./icons/GitHub.astro";
import LinkedInIcon from "./icons/LinkedIn.astro";
import InstagramIcon from "./icons/Instagram.astro";
import UrlIcon from "./icons/Link.astro";
import GoIcon from "./icons/Go.astro";
---

<div
  id="presentacion"
  class="min-h-screen pt-12 md:pt-24 px-4 relative max-w-screen-lg mx-auto bg-gradient-to-b from-sky-50 to-white"
>
  <div class="flex flex-col items-center">
    <!-- Profile Image -->
    <div class="mb-8 relative group">
      <div
        class="absolute -inset-1 bg-gradient-to-r from-sky-300 to-gray-400 rounded-full blur opacity-30 group-hover:opacity-50 transition duration-1000"
      >
      </div>
      <img
        src="/dev.webp"
        class="w-64 h-64 md:w-72 md:h-72 object-cover rounded-full shadow-xl ring-2 ring-sky-50 transition-transform duration-300 hover:scale-105"
        alt="Ronaldo Jiménez"
      />
    </div>

    <!-- Name & Title -->
    <h1
      class="text-3xl md:text-5xl font-bold text-center mb-2 bg-gradient-to-r from-sky-400 to-sky-600 bg-clip-text text-transparent"
    >
      Ronaldo Jiménez
    </h1>

    <div class="flex items-center gap-2 mb-6">
      <span class="text-sky-600">●</span>
      <h2 class="text-xl md:text-2xl font-medium text-gray-700">
        Software Engineer
      </h2>
      <span class="text-sky-400">●</span>
    </div>

    <!-- Profile Info -->
    <div class="max-w-2xl text-center mb-8 space-y-3 px-4">
      <div class="flex items-center justify-center gap-2">
        <div
          class="px-3 py-1 bg-sky-100 text-sky-700 rounded-full text-sm font-medium"
        >
          🚀 5+ años de experiencia
        </div>
      </div>

      <p class="text-gray-600 leading-relaxed mt-4">
        Ingeniero Informático apasionado por el desarrollo de software y la
        docencia.
      </p>
    </div>

    <!-- Social Links -->
    <div class="w-full max-w-2xl space-y-4">
      <div class="flex flex-wrap justify-center gap-3">
        <!-- Web Personal -->
        <SocialButton
          href="https://www.jimcostdev.com/"
          bgColor="hover:bg-sky-600/10"
          borderColor="border-gray-600"
        >
          <UrlIcon class="size-5 md:size-6 text-gray-600" />
          <span class="text-gray-600 font-medium">JimcostDev</span>
        </SocialButton>

        <!-- LinkedIn -->
        <SocialButton
          href="https://www.linkedin.com/in/ronaldo-jimenez"
          bgColor="hover:bg-sky-600/10"
          borderColor="border-gray-600"
        >
          <LinkedInIcon class="size-5 md:size-6 text-gray-600" />
          <span class="text-gray-600 font-medium">LinkedIn</span>
        </SocialButton>

        <!-- Go.Curso -->
        <SocialButton
          href="https://golang.jimcostdev.com/"
          bgColor="hover:bg-sky-600/10"
          borderColor="border-gray-600"
        >
          <GoIcon class="size-8 md:size-10 text-gray-600" />
          <span class="text-gray-600 font-medium">Aprende a Programar</span>
        </SocialButton>
        
        <!-- GitHub -->
        <SocialButton
          href="https://github.com/JimcostDev"
          bgColor="hover:bg-sky-600/10"
          borderColor="border-gray-600"
        >
          <GitHubIcon class="size-5 md:size-6 text-gray-600" />
          <span class="text-gray-600 font-medium">GitHub</span>
        </SocialButton>

        <!-- YouTube -->
        <SocialButton
          href="https://www.youtube.com/@jimcostdev?sub_confirmation=1"
          bgColor="hover:bg-sky-600/10"
          borderColor="border-gray-600"
        >
          <YoutubeIcon class="size-5 md:size-6 text-gray-600" />
          <span class="text-gray-600 font-medium">YouTube</span>
        </SocialButton>
    
        <!-- Instagram -->
        <SocialButton
          href="https://www.instagram.com/jimcostdev/"
          bgColor="hover:bg-sky-600/10"
          borderColor="border-gray-600"
        >
          <InstagramIcon class="size-5 md:size-6 text-gray-600" />
          <span class="text-gray-600 font-medium">Instagram</span>
        </SocialButton>
      </div>
    </div>
  </div>
</div>
