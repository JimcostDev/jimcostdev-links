---
---
<footer class="bg-gradient-to-b from-white to-sky-50/50 py-12 mt-2">
	<div class="max-w-4xl mx-auto px-4 flex flex-col items-center space-y-6">
	  <!-- Logo con efecto de gradiente -->
	  <div class="group relative">
		<div class="absolute -inset-1 bg-gradient-to-r from-sky-400 to-sky-600 rounded-full blur opacity-20 group-hover:opacity-30 transition duration-500"></div>
		<img
		  src="/logo.svg"
		  width="96"
		  height="96"
		  alt="jimcostdev logo"
		  class="relative z-10 mb-2 opacity-90 transition-transform duration-300 hover:scale-105 hover:opacity-100"
		/>
	  </div>
  
	  <!-- Frase motivacional -->
	   <blockquote class="text-base italic text-gray-700 px-4 max-w-lg my-4">
		"Ponte un blanco alto y haz fervientes esfuerzos por alcanzarlo y no te desanimes" <span class="font-semibold">EGW</span>
	  </blockquote>
  
	  <!-- Divisor con gradiente -->
	  <div class="w-full max-w-xs h-px bg-gradient-to-r from-transparent via-sky-300 to-transparent my-6"></div>
  
	  <!-- Derechos de autor -->
	  <p class="text-sm md:text-base text-gray-600 font-medium">
		Hecho con <span class="text-blue-600 animate-pulse">💙</span>
		© Ronaldo Jiménez <span id="currentYear" class="font-semibold bg-gradient-to-r from-sky-400 to-sky-600 bg-clip-text text-transparent"></span>
	  </p>
	</div>
  </footer>
  
  <script>
	// Obtener el elemento donde mostrar el año
	const yearElement = document.getElementById("currentYear");
  
	// Actualizar con el año actual del cliente
	if (yearElement) {
	  yearElement.textContent = new Date().getFullYear().toString();
	}
  </script>